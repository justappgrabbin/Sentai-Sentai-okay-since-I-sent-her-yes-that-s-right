  "key_findings": [
    "Emotion mediation robustly explains 60-75% of variance in color associations",
    "Happy -> light yellow (large)",
    "Anger -> dark red-yellow/terracotta (large)",
    "Sad -> dark blue-grey (small)",
    "Tender -> light violet (small)",
    "Fear -> dark muted grey (medium)",
    "Low valence -> large red-yellow; High valence -> small green-blue",
    "Low energy -> small dark blue; High energy -> large red-yellow",
    "Low tension -> lighter; High tension -> darker"
