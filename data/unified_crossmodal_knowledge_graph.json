{
  "meta": {
    "title": "Unified Crossmodal Knowledge Graph for MRNN",
    "version": "1.0",
    "sources": [
      "Lindborg et al. (2015) PMC4671663",
      "Wikipedia - Chromesthesia",
      "Ivanov et al. (2019) arXiv:1910.12091"
    ],
    "purpose": "Bridge music, color, emotion, and graph structure for MRNN message passing"
  },
  "nodes": {
    "sound": {
      "type": "modality",
      "dimensions": [
        "pitch",
        "timbre",
        "loudness",
        "duration",
        "attack",
        "spectral_centroid"
      ],
      "d_level": 1,
      "description": "Raw acoustic signal - D1 impulse layer"
    },
    "color": {
      "type": "modality",
      "dimensions": [
        "lightness",
        "hue",
        "saturation",
        "a_star",
        "b_star"
      ],
      "d_level": 2,
      "description": "Visual color perception - D2 polarity layer",
      "space": "CIE Lab"
    },
    "shape": {
      "type": "modality",
      "dimensions": [
        "size",
        "roundness",
        "complexity",
        "movement"
      ],
      "d_level": 2,
      "description": "Visual shape perception - D2 polarity layer"
    },
    "emotion_discrete": {
      "type": "emotion_archetype",
      "values": [
        "anger",
        "fear",
        "happy",
        "sad",
        "tender"
      ],
      "d_level": 5,
      "description": "Discrete emotion attractors - D5 meaning layer"
    },
    "emotion_dimensional": {
      "type": "emotion_field",
      "dimensions": [
        "valence",
        "energy",
        "tension"
      ],
      "range": [
        -1,
        1
      ],
      "d_level": 4,
      "description": "Continuous emotion coordinates - D4 context layer"
    },
    "attention": {
      "type": "cognitive_mechanism",
      "d_level": 3,
      "description": "D3 witness/observer - attention modulates crossmodal binding",
      "chromesthesia_evidence": "59% of synesthetes report attention influences experience"
    },
    "memory": {
      "type": "cognitive_mechanism",
      "d_level": 4,
      "description": "D4 context - learned associations stabilize over time",
      "chromesthesia_evidence": "Mappings are idiosyncratic but consistent over years"
    },
    "V4": {
      "type": "brain_region",
      "function": "Color processing",
      "chromesthesia_role": "Activated immediately after auditory input"
    },
    "auditory_cortex": {
      "type": "brain_region",
      "function": "Sound processing",
      "chromesthesia_role": "Inducer pathway"
    },
    "inferior_parietal": {
      "type": "brain_region",
      "function": "Multisensory binding",
      "chromesthesia_role": "Binds real and synesthetic perceptions"
    },
    "fusiform_gyrus": {
      "type": "brain_region",
      "function": "Projector-type chromesthesia",
      "chromesthesia_role": "External space photisms"
    },
    "angular_gyrus": {
      "type": "brain_region",
      "function": "Associator-type chromesthesia",
      "chromesthesia_role": "Mind's eye photisms"
    }
  },
  "edges": {
    "sound_pitch\u2192color_lightness": {
      "weight": 0.73,
      "source": "Lindborg: spectral_flux\u2192size",
      "type": "direct_correlation",
      "note": "High pitch = light color (universal tendency)"
    },
    "sound_pitch\u2192color_hue": {
      "weight": 0.55,
      "source": "Lindborg: spectral_entropy\u2192a_star",
      "type": "direct_correlation"
    },
    "sound\u2192emotion": {
      "weight": 0.85,
      "source": "Lindborg: emotion explains 60-75% of color variance",
      "type": "mediated",
      "path": "sound \u2192 emotion_discrete \u2192 color"
    },
    "emotion\u2192color": {
